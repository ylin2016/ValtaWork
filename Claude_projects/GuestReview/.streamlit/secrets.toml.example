# Copy this file's CONTENTS into the Streamlit Cloud app's Secrets box
# (App → Settings → Secrets). For local testing, save a real copy as
# .streamlit/secrets.toml — that filename is git-ignored.
#
# [gdrive.service_account] = paste the entire service-account JSON key, one
# field per line. Keep private_key as a single line with literal \n escapes
# (TOML turns \n into real newlines).

[gdrive.service_account]
type = "service_account"
project_id = "your-gcp-project"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
client_email = "guest-reviews@your-gcp-project.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/guest-reviews%40your-gcp-project.iam.gserviceaccount.com"
universe_domain = "googleapis.com"

# config.yml path-key  ->  Google Drive file ID (the long token in the file's
# share link: https://drive.google.com/file/d/<FILE_ID>/view)
[gdrive.file_ids]
reviews_xlsx     = "PASTE_DRIVE_FILE_ID"
baseline_xlsx    = "PASTE_DRIVE_FILE_ID"
listing_contacts = "PASTE_DRIVE_FILE_ID"
